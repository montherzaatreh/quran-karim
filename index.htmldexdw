<!-- ══════ FONTS ══════ -->
<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Amiri+Quran&family=Amiri:wght@400;700&family=Scheherazade+New:wght@400;700&family=Cairo:wght@300;400;600;700;800&display=swap" rel="stylesheet">

<style>
/* ══════════════════════════════════════════════════════════════
   CSS CUSTOM PROPERTIES
══════════════════════════════════════════════════════════════ */
:root {
  /* Dawn / Fajr Mode – بيج ملكي */
  --bg:           #fcfbf7;
  --bg2:          #f5f0e8;
  --surface:      #ffffff;
  --surface2:     #f0ead8;
  --surface3:     #e8dfc8;
  --border:       #ddd0b8;
  --border2:      #c9b898;
  --text:         #1e1408;
  --text2:        #6b5535;
  --text3:        #9a7c55;
  --accent:       #8e734b;
  --accent-light: #b8976a;
  --accent-dark:  #5e4a2e;
  --gold:         #8e734b;
  --gold2:        #c9a55a;
  --gold3:        #f0d080;
  --shadow:       rgba(142,115,75,0.15);
  --shadow2:      rgba(142,115,75,0.08);
  --radius:       16px;
  --radius2:      10px;
  --bar-h:        70px;
  --font-quran:   28px;
  --mode-label:   'وضع الصبح ☀️';
}

.dark {
  /* Night / Isha Mode – عتمة ملكية */
  --bg:           #0d0c09;
  --bg2:          #131109;
  --surface:      #1c1912;
  --surface2:     #221f16;
  --surface3:     #2e2a1e;
  --border:       #3d3828;
  --border2:      #554e38;
  --text:         #f0e6d0;
  --text2:        #c9b080;
  --text3:        #8a7050;
  --accent:       #c9a55a;
  --accent-light: #e0c080;
  --accent-dark:  #8e734b;
  --gold:         #d4a843;
  --gold2:        #b88a30;
  --gold3:        #7a5820;
  --shadow:       rgba(0,0,0,0.5);
  --shadow2:      rgba(0,0,0,0.3);
}

/* ══════════════════════════════════════════════════════════════
   RESET
══════════════════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Cairo', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100dvh;
  transition: background .35s ease, color .35s ease;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}

/* ══════════════════════════════════════════════════════════════
   ROYAL HEADER – الهيدر الملكي
   بسملة + اسم السورة + رقم الصفحة في سطر واحد ثابت
══════════════════════════════════════════════════════════════ */
#topbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 500;
  height: var(--bar-h);
  background: linear-gradient(135deg, var(--accent-dark) 0%, var(--accent) 50%, var(--accent-light) 100%);
  border-bottom: 2px solid var(--gold2);
  box-shadow: 0 3px 20px var(--shadow);
  display: flex;
  align-items: center;
  padding: 0 14px;
  gap: 10px;
  transition: background .35s;
}

/* Decorative shimmer line */
#topbar::after {
  content: '';
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, var(--gold3) 30%, var(--gold2) 50%, var(--gold3) 70%, transparent 100%);
}

/* ── Close button (reader only) ── */
#btn-close {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.25);
  color: #fff;
  font-size: 18px;
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background .2s, transform .2s;
}
#btn-close:hover { background: rgba(220,50,50,0.7); transform: scale(1.1); }
body.reading #btn-close { display: flex; }

/* ── Centre slot ── */
#bar-centre {
  flex: 1;
  text-align: center;
  overflow: hidden;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1px;
}

/* HOME: شعار الموقع */
#bar-logo-wrap { display: flex; flex-direction: column; align-items: center; }
#bar-logo {
  font-family: 'Amiri Quran', 'Amiri', serif;
  font-size: 26px;
  color: #fff;
  line-height: 1;
  letter-spacing: 2px;
  text-shadow: 0 1px 6px rgba(0,0,0,0.3);
}
#bar-logo-sub {
  font-family: 'Cairo', sans-serif;
  font-size: 11px;
  color: rgba(255,255,255,0.75);
  margin-top: 2px;
}

/* READER: البسملة + اسم السورة + رقم الصفحة */
#bar-reader-wrap {
  display: none;
  flex-direction: column;
  align-items: center;
  gap: 0;
  width: 100%;
}
#bar-basmalah {
  font-family: 'Amiri Quran', 'Scheherazade New', serif;
  font-size: clamp(15px, 3.5vw, 21px);
  color: var(--gold3);
  text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}
#bar-surah-row {
  display: flex;
  align-items: center;
  gap: 8px;
  line-height: 1;
}
#bar-surah-name {
  font-family: 'Amiri', serif;
  font-size: clamp(14px, 3vw, 18px);
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 700;
}
#bar-separator { color: rgba(255,255,255,0.4); font-size: 12px; }
#bar-page-info {
  font-family: 'Cairo', sans-serif;
  font-size: clamp(10px, 2.2vw, 13px);
  color: rgba(255,255,255,0.8);
  white-space: nowrap;
}

body.reading #bar-logo-wrap    { display: none; }
body.reading #bar-reader-wrap  { display: flex; }

/* ── Right controls ── */
#bar-right {
  display: flex;
  align-items: center;
  gap: 5px;
  flex-shrink: 0;
}

.font-grp { display: none; align-items: center; gap: 4px; }
body.reading .font-grp { display: flex; }

.icon-btn {
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.2);
  color: #fff;
  border-radius: 10px;
  width: 36px; height: 36px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 15px;
  flex-shrink: 0;
  transition: background .2s, transform .15s;
  font-family: 'Cairo', sans-serif;
  font-weight: 700;
}
.icon-btn:hover { background: rgba(255,255,255,0.25); transform: scale(1.08); }
.icon-btn:active { transform: scale(0.95); }

/* ══════════════════════════════════════════════════════════════
   HOME SCREEN
══════════════════════════════════════════════════════════════ */
#home {
  padding: calc(var(--bar-h) + 20px) 16px 60px;
  max-width: 1050px;
  margin: 0 auto;
}

/* Page title banner */
.page-title {
  text-align: center;
  margin-bottom: 22px;
  padding: 20px;
  background: linear-gradient(135deg, var(--surface2) 0%, var(--surface) 100%);
  border: 1px solid var(--border);
  border-radius: 20px;
  position: relative;
  overflow: hidden;
}
.page-title::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(142,115,75,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.page-title h1 {
  font-family: 'Amiri Quran', serif;
  font-size: clamp(36px, 8vw, 54px);
  color: var(--accent);
  line-height: 1.3;
}
.page-title p {
  font-size: 13px;
  color: var(--text2);
  margin-top: 6px;
}

/* ── Tabs: سور / أجزاء ── */
#tab-bar {
  display: flex;
  gap: 0;
  margin-bottom: 16px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 4px;
}
.tab-btn {
  flex: 1;
  padding: 10px 0;
  border-radius: 10px;
  border: none;
  background: transparent;
  color: var(--text2);
  font-family: 'Cairo', sans-serif;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: background .2s, color .2s, box-shadow .2s;
}
.tab-btn.active {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 2px 10px var(--shadow);
}

/* ── Search ── */
#search-wrap {
  position: relative;
  margin-bottom: 18px;
}
#search {
  width: 100%;
  padding: 13px 18px 13px 48px;
  border-radius: 14px;
  border: 1.5px solid var(--border);
  background: var(--surface);
  color: var(--text);
  font-family: 'Cairo', sans-serif;
  font-size: 15px;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
  -webkit-appearance: none;
}
#search:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(142,115,75,0.14);
}
#search::placeholder { color: var(--text3); }
.search-icon {
  position: absolute;
  left: 14px; top: 50%;
  transform: translateY(-50%);
  color: var(--text2);
  font-size: 18px;
  pointer-events: none;
}

/* ── Surah grid ── */
#surah-grid, #juz-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
  gap: 11px;
}
#juz-grid { display: none; }

.surah-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 13px 15px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 12px;
  position: relative;
  overflow: hidden;
  transition: transform .2s, box-shadow .2s, border-color .2s;
}
.surah-card::before {
  content: '';
  position: absolute;
  right: 0; top: 0; bottom: 0; width: 4px;
  background: linear-gradient(180deg, var(--gold2), var(--accent));
  opacity: 0;
  transition: opacity .2s;
}
.surah-card:hover, .surah-card:focus-visible {
  box-shadow: 0 5px 20px var(--shadow);
  transform: translateY(-2px);
  border-color: var(--accent-light);
  outline: none;
}
.surah-card:hover::before, .surah-card:focus-visible::before { opacity: 1; }

.surah-num {
  width: 40px; height: 40px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700;
  color: var(--accent);
  flex-shrink: 0;
}
.surah-info { flex: 1; min-width: 0; }
.surah-ar {
  font-family: 'Amiri', serif;
  font-size: 18px;
  color: var(--text);
  line-height: 1.3;
}
.surah-en {
  font-size: 11px;
  color: var(--text2);
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.surah-meta { font-size: 11px; color: var(--accent); margin-top: 3px; }
.surah-tag { font-size: 18px; flex-shrink: 0; }

/* Juz cards */
.juz-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 14px;
  transition: transform .2s, box-shadow .2s, border-color .2s;
  position: relative;
  overflow: hidden;
}
.juz-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 20px var(--shadow);
  border-color: var(--accent-light);
}
.juz-num {
  width: 50px; height: 50px;
  background: linear-gradient(135deg, var(--accent-dark), var(--accent));
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Amiri', serif;
  font-size: 22px;
  color: #fff;
  flex-shrink: 0;
  box-shadow: 0 3px 10px var(--shadow);
}
.juz-info h3 {
  font-family: 'Amiri', serif;
  font-size: 17px;
  color: var(--text);
}
.juz-info p {
  font-size: 11px;
  color: var(--text2);
  margin-top: 3px;
}

.no-results {
  text-align: center;
  padding: 60px 20px;
  color: var(--text2);
  font-size: 16px;
  grid-column: 1/-1;
}

/* ══════════════════════════════════════════════════════════════
   READER
══════════════════════════════════════════════════════════════ */
#reader { display: none; }

#ayah-area {
  max-width: 850px;
  margin: 0 auto;
  padding: calc(var(--bar-h) + 28px) 22px 120px;
  min-height: 100dvh;
}

/* Page ornament header */
.page-ornament {
  text-align: center;
  margin-bottom: 20px;
  position: relative;
}
.page-ornament-line {
  display: flex;
  align-items: center;
  gap: 12px;
  justify-content: center;
  margin-bottom: 4px;
}
.ornament-dash {
  flex: 1;
  max-width: 100px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold2), transparent);
}
.ornament-diamond {
  color: var(--gold2);
  font-size: 12px;
}
.page-label-text {
  font-family: 'Cairo', sans-serif;
  font-size: 11px;
  color: var(--text3);
  letter-spacing: 1px;
}

/* Basmalah */
.basmalah {
  text-align: center;
  font-family: 'Amiri Quran', 'Scheherazade New', serif;
  font-size: calc(var(--font-quran) * 1.08);
  color: var(--gold);
  margin: 18px 0 24px;
  line-height: 2;
  text-shadow: 0 1px 3px var(--shadow2);
}

/* Surah header inside reader */
.surah-header-reader {
  text-align: center;
  margin-bottom: 20px;
  padding: 14px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 14px;
}
.surah-header-reader h2 {
  font-family: 'Amiri', serif;
  font-size: 24px;
  color: var(--accent);
}
.surah-header-reader p {
  font-size: 12px;
  color: var(--text2);
  margin-top: 4px;
}

/* Quran text */
#quran-text {
  font-family: 'Amiri Quran', 'Scheherazade New', serif;
  font-size: var(--font-quran);
  line-height: 2.6;
  text-align: justify;
  color: var(--text);
  direction: rtl;
  word-spacing: 4px;
}

/* Ayah number ornament – كرسي الآية */
.ayah-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  position: relative;
  margin: 0 4px;
  vertical-align: middle;
  font-family: 'Cairo', sans-serif;
  font-size: 10px;
  font-weight: 700;
  color: var(--gold);
}
.ayah-num::before {
  content: '۞';
  position: absolute;
  font-family: 'Amiri Quran', serif;
  font-size: 28px;
  color: var(--gold2);
  opacity: 0.7;
  line-height: 1;
}
.ayah-num span {
  position: relative;
  z-index: 1;
  font-size: 9px;
}

/* Hizb marker */
.hizb-marker {
  display: inline-block;
  width: 18px; height: 18px;
  background: var(--gold2);
  border-radius: 50%;
  margin: 0 3px;
  vertical-align: middle;
  font-size: 8px;
  line-height: 18px;
  text-align: center;
  color: var(--surface);
  font-weight: 700;
}

/* ══════════════════════════════════════════════════════════════
   PAGINATION
══════════════════════════════════════════════════════════════ */
#pagination {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  z-index: 400;
  background: var(--surface);
  border-top: 1px solid var(--border);
  padding: 10px 16px;
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  box-shadow: 0 -3px 16px var(--shadow2);
  transition: background .35s;
}

.page-btn {
  padding: 10px 20px;
  border-radius: 12px;
  cursor: pointer;
  background: var(--surface2);
  border: 1.5px solid var(--border);
  color: var(--text);
  font-family: 'Cairo', sans-serif;
  font-size: 14px;
  font-weight: 600;
  transition: background .2s, color .2s, transform .15s;
  white-space: nowrap;
}
.page-btn:hover:not(:disabled) {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
  transform: scale(1.03);
}
.page-btn:active:not(:disabled) { transform: scale(0.97); }
.page-btn:disabled { opacity: .35; cursor: default; }

#page-counter-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  flex: 1;
}
#page-counter {
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  color: var(--text2);
  white-space: nowrap;
}

/* Progress bar */
#progress-bar-wrap {
  width: 100%;
  max-width: 200px;
  height: 4px;
  background: var(--surface3);
  border-radius: 2px;
  overflow: hidden;
}
#progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-dark), var(--gold2));
  border-radius: 2px;
  transition: width .3s ease;
}

/* ══════════════════════════════════════════════════════════════
   LOADER
══════════════════════════════════════════════════════════════ */
#loader {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 600;
  background: var(--bg);
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 20px;
}
#loader.active { display: flex; }

.loader-logo {
  font-family: 'Amiri Quran', serif;
  font-size: 42px;
  color: var(--accent);
  animation: pulse-logo 1.5s ease-in-out infinite;
}
@keyframes pulse-logo {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: .6; transform: scale(.96); }
}
.spinner {
  width: 44px; height: 44px;
  border: 3px solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin .75s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
#loader p {
  font-family: 'Cairo', sans-serif;
  font-size: 14px;
  color: var(--text2);
}

/* ══════════════════════════════════════════════════════════════
   TOAST
══════════════════════════════════════════════════════════════ */
.toast {
  position: fixed;
  bottom: 90px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: var(--accent);
  color: #fff;
  padding: 12px 24px;
  border-radius: 14px;
  font-family: 'Cairo', sans-serif;
  font-size: 14px;
  z-index: 700;
  box-shadow: 0 5px 24px var(--shadow);
  max-width: 90vw;
  text-align: center;
  direction: rtl;
  animation: toast-in .3s ease forwards;
}
@keyframes toast-in {
  to { transform: translateX(-50%) translateY(0); opacity: 1; }
}

/* ══════════════════════════════════════════════════════════════
   LAST PAGE BADGE (persistence)
══════════════════════════════════════════════════════════════ */
#last-read-badge {
  display: none;
  margin-bottom: 16px;
  padding: 12px 16px;
  background: linear-gradient(135deg, var(--surface2), var(--surface));
  border: 1px solid var(--accent-light);
  border-radius: 14px;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  transition: box-shadow .2s;
}
#last-read-badge:hover { box-shadow: 0 4px 16px var(--shadow); }
#last-read-badge .badge-icon { font-size: 22px; flex-shrink: 0; }
#last-read-badge .badge-text h3 { font-size: 14px; color: var(--accent); font-weight: 700; }
#last-read-badge .badge-text p  { font-size: 12px; color: var(--text2); margin-top: 2px; }
#last-read-badge .badge-arrow   { margin-right: auto; color: var(--accent); font-size: 18px; }

/* ══════════════════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════════════════ */
@media (max-width: 480px) {
  :root { --font-quran: 22px; --bar-h: 62px; }
  #bar-basmalah { font-size: 14px; }
  #surah-grid, #juz-grid { grid-template-columns: 1fr; }
  .page-btn { padding: 9px 14px; font-size: 13px; }
  #ayah-area { padding-left: 14px; padding-right: 14px; }
}
@media (min-width: 481px) and (max-width: 768px) {
  :root { --font-quran: 24px; --bar-h: 65px; }
  #surah-grid, #juz-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 769px) {
  :root { --font-quran: 27px; --bar-h: 70px; }
  #surah-grid, #juz-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (min-width: 1100px) {
  :root { --font-quran: 29px; }
  #surah-grid, #juz-grid { grid-template-columns: repeat(4, 1fr); }
  #juz-grid { grid-template-columns: repeat(5, 1fr); }
}

@media (pointer: coarse) {
  .icon-btn { width: 42px; height: 42px; }
  .surah-card { padding: 15px 16px; }
}

@media print {
  #topbar, #pagination, #loader, #last-read-badge { display: none !important; }
  #ayah-area { padding-top: 10px !important; }
}
</style>
</head>
<body>

<!-- ══════════════════════════════════════════════════════════════
     LOADER
══════════════════════════════════════════════════════════════ -->
<div id="loader" role="status" aria-live="polite">
  <div class="loader-logo">القرآن الكريم</div>
  <div class="spinner"></div>
  <p>جارٍ التحميل…</p>
</div>

<!-- ══════════════════════════════════════════════════════════════
     ROYAL HEADER – الهيدر الملكي
══════════════════════════════════════════════════════════════ -->
<header id="topbar" role="banner">

  <!-- Left: close button (reader only) -->
  <button id="btn-close" aria-label="إغلاق وعودة لقائمة السور (Esc)">✕</button>

  <!-- Centre: logo on home / basmalah+surah+page in reader -->
  <div id="bar-centre">

    <!-- Home view -->
    <div id="bar-logo-wrap">
      <span id="bar-logo">القرآن الكريم</span>
      <span id="bar-logo-sub">١١٤ سورة · ٦٠٤ صفحة · ٣٠ جزءاً</span>
    </div>

    <!-- Reader view: بسملة + اسم السورة + رقم الصفحة -->
    <div id="bar-reader-wrap" aria-live="polite">
      <div id="bar-basmalah">بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ</div>
      <div id="bar-surah-row">
        <span id="bar-surah-name">—</span>
        <span id="bar-separator">·</span>
        <span id="bar-page-info">—</span>
      </div>
    </div>

  </div>

  <!-- Right: font size + dark mode -->
  <div id="bar-right">
    <div class="font-grp" role="group" aria-label="حجم الخط">
      <button class="icon-btn" id="font-down" aria-label="تصغير الخط">−</button>
      <button class="icon-btn" id="font-up"   aria-label="تكبير الخط">+</button>
    </div>
    <button class="icon-btn" id="dark-btn" aria-label="الوضع الليلي" title="تبديل الوضع">🌙</button>
  </div>

</header>

<!-- ══════════════════════════════════════════════════════════════
     HOME SCREEN
══════════════════════════════════════════════════════════════ -->
<main id="home" role="main">

  <div class="page-title">
    <h1>القرآن الكريم</h1>
    <p>اقرأ بالرسم العثماني الأصيل · ١١٤ سورة · ٦٠٤ صفحة · ٣٠ جزءاً</p>
  </div>

  <!-- Last read badge (persistence) -->
  <div id="last-read-badge" role="button" tabindex="0" aria-label="متابعة القراءة من آخر توقف">
    <span class="badge-icon">🔖</span>
    <div class="badge-text">
      <h3 id="badge-title">متابعة القراءة</h3>
      <p  id="badge-sub">—</p>
    </div>
    <span class="badge-arrow">←</span>
  </div>

  <!-- Tabs: سور / أجزاء -->
  <div id="tab-bar" role="tablist" aria-label="تبديل بين السور والأجزاء">
    <button class="tab-btn active" id="tab-suwar" role="tab" aria-selected="true"  aria-controls="surah-grid">📖 السور (١١٤)</button>
    <button class="tab-btn"        id="tab-ajzaa" role="tab" aria-selected="false" aria-controls="juz-grid">📚 الأجزاء (٣٠)</button>
  </div>

  <!-- Search -->
  <div id="search-wrap">
    <span class="search-icon" aria-hidden="true">🔍</span>
    <input type="search" id="search"
           placeholder="ابحث باسم السورة أو رقمها أو بالجزء…"
           autocomplete="off"
           autocorrect="off"
           spellcheck="false"
           aria-label="البحث في قائمة السور">
  </div>

  <!-- Surah grid -->
  <div id="surah-grid" role="list" aria-label="قائمة السور"></div>

  <!-- Juz grid -->
  <div id="juz-grid"   role="list" aria-label="قائمة الأجزاء"></div>

</main>

<!-- ══════════════════════════════════════════════════════════════
     READER
══════════════════════════════════════════════════════════════ -->
<section id="reader" aria-label="صفحة القراءة">
  <div id="ayah-area">
    <div id="quran-text" lang="ar" dir="rtl"></div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════
     PAGINATION
══════════════════════════════════════════════════════════════ -->
<nav id="pagination" aria-label="التنقل بين صفحات السورة">
  <button class="page-btn" id="prev-btn" aria-label="الصفحة السابقة">&#8592; السابق</button>
  <div id="page-counter-wrap">
    <span id="page-counter" aria-live="polite">—</span>
    <div id="progress-bar-wrap" aria-hidden="true">
      <div id="progress-bar-fill"></div>
    </div>
  </div>
  <button class="page-btn" id="next-btn" aria-label="الصفحة التالية">التالي &#8594;</button>
</nav>

<!-- ══════════════════════════════════════════════════════════════
     JAVASCRIPT
══════════════════════════════════════════════════════════════ -->
<script>
/* ════════════════════════════════════════════════
   CONSTANTS & STATE
════════════════════════════════════════════════ */
const BASMALAH_TEXT = 'بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ';
const API_BASE      = 'https://api.alquran.cloud/v1';

/* Juz data: number → first page in mushaf (approximate standard pages) */
const JUZ_DATA = [
  { num:1,  name:'الجزء الأول',   startPage:1,   firstSurah:'الفاتحة',      info:'الفاتحة – البقرة ١٤١' },
  { num:2,  name:'الجزء الثاني',  startPage:22,  firstSurah:'البقرة',       info:'البقرة ١٤٢ – ٢٥٢' },
  { num:3,  name:'الجزء الثالث',  startPage:42,  firstSurah:'البقرة',       info:'البقرة ٢٥٣ – آل عمران ٩١' },
  { num:4,  name:'الجزء الرابع',  startPage:62,  firstSurah:'آل عمران',     info:'آل عمران ٩٢ – النساء ٢٣' },
  { num:5,  name:'الجزء الخامس',  startPage:82,  firstSurah:'النساء',       info:'النساء ٢٤ – ١٤٧' },
  { num:6,  name:'الجزء السادس',  startPage:102, firstSurah:'النساء',       info:'النساء ١٤٨ – المائدة ٨١' },
  { num:7,  name:'الجزء السابع',  startPage:121, firstSurah:'المائدة',      info:'المائدة ٨٢ – الأنعام ١١٠' },
  { num:8,  name:'الجزء الثامن',  startPage:142, firstSurah:'الأنعام',      info:'الأنعام ١١١ – الأعراف ٨٧' },
  { num:9,  name:'الجزء التاسع',  startPage:162, firstSurah:'الأعراف',      info:'الأعراف ٨٨ – الأنفال ٤٠' },
  { num:10, name:'الجزء العاشر',  startPage:182, firstSurah:'الأنفال',      info:'الأنفال ٤١ – التوبة ٩٢' },
  { num:11, name:'الجزء الحادي عشر', startPage:201, firstSurah:'التوبة',   info:'التوبة ٩٣ – هود ٥' },
  { num:12, name:'الجزء الثاني عشر', startPage:221, firstSurah:'هود',      info:'هود ٦ – يوسف ٥٢' },
  { num:13, name:'الجزء الثالث عشر', startPage:242, firstSurah:'يوسف',     info:'يوسف ٥٣ – إبراهيم ٥١' },
  { num:14, name:'الجزء الرابع عشر', startPage:262, firstSurah:'الحجر',    info:'الحجر – النحل ١٢٨' },
  { num:15, name:'الجزء الخامس عشر', startPage:282, firstSurah:'الإسراء',  info:'الإسراء – الكهف ٧٤' },
  { num:16, name:'الجزء السادس عشر', startPage:302, firstSurah:'الكهف',    info:'الكهف ٧٥ – طه ١٣٥' },
  { num:17, name:'الجزء السابع عشر', startPage:322, firstSurah:'الأنبياء', info:'الأنبياء – الحج ٧٨' },
  { num:18, name:'الجزء الثامن عشر', startPage:342, firstSurah:'المؤمنون', info:'المؤمنون – الفرقان ٢٠' },
  { num:19, name:'الجزء التاسع عشر', startPage:362, firstSurah:'الفرقان',  info:'الفرقان ٢١ – النمل ٥٥' },
  { num:20, name:'الجزء العشرون',    startPage:382, firstSurah:'النمل',    info:'النمل ٥٦ – العنكبوت ٤٥' },
  { num:21, name:'الجزء الحادي والعشرون', startPage:402, firstSurah:'العنكبوت', info:'العنكبوت ٤٦ – الأحزاب ٣٠' },
  { num:22, name:'الجزء الثاني والعشرون', startPage:422, firstSurah:'الأحزاب', info:'الأحزاب ٣١ – يس ٢٧' },
  { num:23, name:'الجزء الثالث والعشرون', startPage:442, firstSurah:'يس',   info:'يس ٢٨ – الزمر ٣١' },
  { num:24, name:'الجزء الرابع والعشرون', startPage:462, firstSurah:'الزمر', info:'الزمر ٣٢ – فصلت ٤٦' },
  { num:25, name:'الجزء الخامس والعشرون', startPage:482, firstSurah:'فصلت', info:'فصلت ٤٧ – الجاثية ٣٧' },
  { num:26, name:'الجزء السادس والعشرون', startPage:502, firstSurah:'الأحقاف', info:'الأحقاف – الذاريات ٣٠' },
  { num:27, name:'الجزء السابع والعشرون', startPage:522, firstSurah:'الذاريات', info:'الذاريات ٣١ – الحديد ٢٩' },
  { num:28, name:'الجزء الثامن والعشرون', startPage:542, firstSurah:'المجادلة', info:'المجادلة – التحريم' },
  { num:29, name:'الجزء التاسع والعشرون', startPage:562, firstSurah:'الملك',   info:'الملك – المرسلات' },
  { num:30, name:'الجزء الثلاثون',        startPage:582, firstSurah:'النبأ',   info:'النبأ – الناس' }
];

/* App state */
let allSurahs      = [];
let currentSurah   = null;
let allPages       = [];
let currentPageIdx = 0;
let activeTab      = 'suwar';   // 'suwar' | 'ajzaa'

/* Settings from localStorage */
let fontSize = parseInt(localStorage.getItem('qk_fontSize') || '26');
let darkMode = localStorage.getItem('qk_dark') === '1';

/* ════════════════════════════════════════════════
   PWA MANIFEST – generated inline
════════════════════════════════════════════════ */
(function injectManifest() {
  const manifest = {
    name: 'القرآن الكريم',
    short_name: 'القرآن',
    description: 'مصحف إلكتروني كامل بالرسم العثماني – 604 صفحة',
    start_url: window.location.pathname,
    display: 'standalone',
    orientation: 'portrait',
    background_color: '#fcfbf7',
    theme_color: '#8e734b',
    lang: 'ar',
    dir: 'rtl',
    icons: [
      {
        src: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'%3E%3Crect width='192' height='192' rx='40' fill='%238e734b'/%3E%3Ctext y='155' x='25' font-size='140' font-family='serif'%3E📖%3C/text%3E%3C/svg%3E",
        sizes: '192x192', type: 'image/svg+xml'
      },
      {
        src: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='80' fill='%238e734b'/%3E%3Ctext y='420' x='50' font-size='380' font-family='serif'%3E📖%3C/text%3E%3C/svg%3E",
        sizes: '512x512', type: 'image/svg+xml', purpose: 'any maskable'
      }
    ],
    categories: ['books', 'education', 'religion']
  };
  const blob = new Blob([JSON.stringify(manifest)], { type: 'application/manifest+json' });
  const url  = URL.createObjectURL(blob);
  document.getElementById('pwaManifest').setAttribute('href', url);
})();

/* ════════════════════════════════════════════════
   NORMALIZE – Arabic text normalization
   Strips harakat, tatweel, hamza variants, taa marbuta
════════════════════════════════════════════════ */
function normalizeArabic(str) {
  if (!str) return '';
  return str
    .replace(/[\u0610-\u061A\u064B-\u065F\u0670]/g, '')   // harakat & diacritics
    .replace(/\u0640/g, '')                                   // tatweel
    .replace(/[\u0622\u0623\u0625\u0671]/g, '\u0627')        // hamza variants → alef
    .replace(/\u0629/g, '\u0647')                             // taa marbuta → haa
    .replace(/\u0649/g, '\u064A')                             // alef maqsura → yaa
    .replace(/\s+/g, ' ')
    .trim();
}

/* ════════════════════════════════════════════════
   THEME & FONT SIZE
════════════════════════════════════════════════ */
function applyFontSize(s) {
  fontSize = Math.max(18, Math.min(54, s));
  document.documentElement.style.setProperty('--font-quran', fontSize + 'px');
  localStorage.setItem('qk_fontSize', fontSize);
}

function applyDark(on) {
  darkMode = on;
  document.body.classList.toggle('dark', on);
  const btn = document.getElementById('dark-btn');
  if (on) {
    btn.textContent = '☀️';
    btn.setAttribute('aria-label', 'تفعيل وضع الصبح');
    btn.setAttribute('title', 'وضع الصبح');
  } else {
    btn.textContent = '🌙';
    btn.setAttribute('aria-label', 'تفعيل وضع العتمة');
    btn.setAttribute('title', 'وضع العتمة');
  }
  document.getElementById('themeColorMeta').setAttribute('content', on ? '#1c1912' : '#8e734b');
  localStorage.setItem('qk_dark', on ? '1' : '0');
}

/* Initialize theme & font */
applyFontSize(fontSize);
applyDark(darkMode);

document.getElementById('dark-btn' ).addEventListener('click', () => applyDark(!darkMode));
document.getElementById('font-up'  ).addEventListener('click', () => applyFontSize(fontSize + 2));
document.getElementById('font-down').addEventListener('click', () => applyFontSize(fontSize - 2));

/* ════════════════════════════════════════════════
   PERSISTENCE – last page across sessions
════════════════════════════════════════════════ */
function savePosition(surahNum, pageIdx, surahName) {
  localStorage.setItem('qk_last', JSON.stringify({ surahNum, pageIdx, surahName, ts: Date.now() }));
}

function loadLastPosition() {
  try {
    const raw = localStorage.getItem('qk_last');
    if (!raw) return null;
    return JSON.parse(raw);
  } catch (e) { return null; }
}

function showLastReadBadge() {
  const last = loadLastPosition();
  if (!last) return;
  const badge = document.getElementById('last-read-badge');
  document.getElementById('badge-title').textContent = 'متابعة القراءة – ' + (last.surahName || '');
  document.getElementById('badge-sub').textContent   = 'الصفحة ' + (last.pageIdx + 1) + ' من السورة';
  badge.style.display = 'flex';

  const resume = () => openSurah(last.surahNum, last.pageIdx);
  badge.addEventListener('click', resume);
  badge.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); resume(); } });
}

/* ════════════════════════════════════════════════
   HASH ROUTING – #surah/3/page/2
════════════════════════════════════════════════ */
function updateHash(surahNum, pageIdx) {
  const hash = '#surah/' + surahNum + '/page/' + pageIdx;
  history.replaceState(null, '', hash);
}

function clearHash() {
  history.replaceState(null, '', window.location.pathname);
}

function parseHash() {
  const h = window.location.hash;
  const m = h.match(/^#surah\/(\d+)\/page\/(\d+)$/);
  if (m) return { surahNum: parseInt(m[1]), pageIdx: parseInt(m[2]) };
  return null;
}

window.addEventListener('popstate', () => {
  const parsed = parseHash();
  if (parsed) {
    openSurah(parsed.surahNum, parsed.pageIdx);
  } else {
    showHome();
  }
});

/* ════════════════════════════════════════════════
   LOAD SURAH LIST
════════════════════════════════════════════════ */
async function loadSurahList() {
  showLoader(true);
  try {
    const res  = await fetch(API_BASE + '/surah');
    const data = await res.json();
    if (data.code !== 200) throw new Error('API error');
    allSurahs = data.data;
    renderSurahGrid(allSurahs);
    renderJuzGrid();
    showLastReadBadge();

    /* Auto-open from hash */
    const parsed = parseHash();
    if (parsed && parsed.surahNum >= 1 && parsed.surahNum <= 114) {
      openSurah(parsed.surahNum, parsed.pageIdx || 0);
      return;
    }

    /* Auto-resume last session */
    const last = loadLastPosition();
    if (last && last.surahNum) {
      /* Don't auto-open – just show badge. User decides. */
    }
  } catch (err) {
    document.getElementById('surah-grid').innerHTML =
      '<div class="no-results">⚠️ تعذّر تحميل البيانات.<br>تأكد من الاتصال بالإنترنت ثم أعد تحميل الصفحة.</div>';
  }
  showLoader(false);
}

/* ════════════════════════════════════════════════
   RENDER SURAH GRID
════════════════════════════════════════════════ */
function renderSurahGrid(list) {
  const grid = document.getElementById('surah-grid');
  if (!list.length) {
    grid.innerHTML = '<div class="no-results">🔍 لا توجد نتائج مطابقة</div>';
    return;
  }
  grid.innerHTML = list.map(s => {
    const isMeccan = s.revelationType === 'Meccan';
    return `
      <div class="surah-card" role="listitem" data-num="${s.number}"
           tabindex="0" aria-label="سورة ${s.name}، ${s.numberOfAyahs} آية، ${isMeccan ? 'مكية' : 'مدنية'}">
        <div class="surah-num" aria-hidden="true">${s.number}</div>
        <div class="surah-info">
          <div class="surah-ar">${s.name}</div>
          <div class="surah-en">${s.englishName} · ${s.englishNameTranslation}</div>
          <div class="surah-meta">${s.numberOfAyahs} آية · ${isMeccan ? 'مكية' : 'مدنية'}</div>
        </div>
        <div class="surah-tag" aria-hidden="true">${isMeccan ? '🕌' : '🕍'}</div>
      </div>
    `;
  }).join('');

  grid.querySelectorAll('.surah-card').forEach(card => {
    const act = () => openSurah(+card.dataset.num);
    card.addEventListener('click', act);
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); act(); }
    });
  });
}

/* ════════════════════════════════════════════════
   RENDER JUZ GRID
════════════════════════════════════════════════ */
function renderJuzGrid() {
  const grid = document.getElementById('juz-grid');
  const arabicNums = ['١','٢','٣','٤','٥','٦','٧','٨','٩','١٠','١١','١٢','١٣','١٤','١٥','١٦','١٧','١٨','١٩','٢٠','٢١','٢٢','٢٣','٢٤','٢٥','٢٦','٢٧','٢٨','٢٩','٣٠'];
  grid.innerHTML = JUZ_DATA.map((j, i) => `
    <div class="juz-card" role="listitem" data-juz="${j.num}" tabindex="0" aria-label="${j.name}">
      <div class="juz-num">${arabicNums[i]}</div>
      <div class="juz-info">
        <h3>${j.name}</h3>
        <p>${j.info}</p>
      </div>
    </div>
  `).join('');

  grid.querySelectorAll('.juz-card').forEach(card => {
    const act = () => openJuz(+card.dataset.juz);
    card.addEventListener('click', act);
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); act(); }
    });
  });
}

/* ════════════════════════════════════════════════
   TABS
════════════════════════════════════════════════ */
document.getElementById('tab-suwar').addEventListener('click', () => switchTab('suwar'));
document.getElementById('tab-ajzaa').addEventListener('click', () => switchTab('ajzaa'));

function switchTab(tab) {
  activeTab = tab;
  document.getElementById('tab-suwar').classList.toggle('active', tab === 'suwar');
  document.getElementById('tab-ajzaa').classList.toggle('active', tab === 'ajzaa');
  document.getElementById('tab-suwar').setAttribute('aria-selected', tab === 'suwar');
  document.getElementById('tab-ajzaa').setAttribute('aria-selected', tab === 'ajzaa');
  document.getElementById('surah-grid').style.display = tab === 'suwar' ? 'grid' : 'none';
  document.getElementById('juz-grid'  ).style.display = tab === 'ajzaa' ? 'grid' : 'none';
  document.getElementById('search-wrap').style.display = tab === 'suwar' ? 'block' : 'none';
}

/* ════════════════════════════════════════════════
   SEARCH with Normalize
════════════════════════════════════════════════ */
document.getElementById('search').addEventListener('input', function() {
  const raw = this.value.trim();
  if (!raw) { renderSurahGrid(allSurahs); return; }
  const q = normalizeArabic(raw).toLowerCase();
  const filtered = allSurahs.filter(s => {
    return normalizeArabic(s.name).includes(q) ||
           normalizeArabic(s.englishName).toLowerCase().includes(q) ||
           String(s.number).includes(raw);
  });
  renderSurahGrid(filtered);
});

/* ════════════════════════════════════════════════
   OPEN JUZ
════════════════════════════════════════════════ */
function openJuz(juzNum) {
  const juzInfo = JUZ_DATA.find(j => j.num === juzNum);
  if (!juzInfo) return;
  /* Find first surah in this juz using alquran.cloud */
  showLoader(true);
  fetch(API_BASE + '/juz/' + juzNum + '/quran-uthmani')
    .then(r => r.json())
    .then(data => {
      if (data.code !== 200) throw new Error();
      /* Get the first surah number from the juz */
      const firstAyah = data.data.ayahs[0];
      openSurah(firstAyah.surah.number, 0);
    })
    .catch(() => {
      toast('⚠️ تعذّر تحميل الجزء، حاول مرة أخرى.');
      showLoader(false);
    });
}

/* ════════════════════════════════════════════════
   OPEN SURAH
════════════════════════════════════════════════ */
async function openSurah(num, targetPageIdx) {
  showLoader(true);
  try {
    const res  = await fetch(API_BASE + '/surah/' + num + '/quran-uthmani');
    const data = await res.json();
    if (data.code !== 200) throw new Error('Failed');
    currentSurah   = data.data;
    allPages       = groupAyahsByPage(currentSurah.ayahs);

    /* Determine starting page index */
    if (typeof targetPageIdx === 'number' && targetPageIdx >= 0) {
      currentPageIdx = Math.min(targetPageIdx, allPages.length - 1);
    } else {
      /* Check localStorage for saved position */
      const savedRaw = localStorage.getItem('qk_pos_' + num);
      currentPageIdx = savedRaw ? Math.min(parseInt(savedRaw), allPages.length - 1) : 0;
    }

    showReader();
    renderPage();
  } catch (err) {
    toast('⚠️ تعذّر تحميل السورة. تأكد من الاتصال وحاول مرة أخرى.');
  }
  showLoader(false);
}

/* ════════════════════════════════════════════════
   GROUP AYAHS BY MUSHAF PAGE
════════════════════════════════════════════════ */
function groupAyahsByPage(ayahs) {
  const map = new Map();
  for (const a of ayahs) {
    if (!map.has(a.page)) {
      map.set(a.page, { page: a.page, firstAyahNum: a.numberInSurah, ayahs: [] });
    }
    map.get(a.page).ayahs.push(a);
  }
  return Array.from(map.values()).sort((x, y) => x.page - y.page);
}

/* ════════════════════════════════════════════════
   RENDER PAGE
════════════════════════════════════════════════ */
function renderPage() {
  const pg = allPages[currentPageIdx];
  if (!pg) return;

  /* Update top bar */
  document.getElementById('bar-surah-name').textContent = currentSurah.name;
  document.getElementById('bar-page-info' ).textContent = 'صفحة ' + pg.page + ' من المصحف';

  /* Update pagination */
  document.getElementById('page-counter').textContent =
    'صفحة ' + (currentPageIdx + 1) + ' من ' + allPages.length;
  document.getElementById('prev-btn').disabled = (currentPageIdx === 0);
  document.getElementById('next-btn').disabled = (currentPageIdx === allPages.length - 1);

  /* Progress bar */
  const pct = allPages.length > 1 ? (currentPageIdx / (allPages.length - 1)) * 100 : 100;
  document.getElementById('progress-bar-fill').style.width = pct + '%';

  /* Save position to localStorage */
  localStorage.setItem('qk_pos_' + currentSurah.number, currentPageIdx);
  savePosition(currentSurah.number, currentPageIdx, currentSurah.name);

  /* Update URL hash */
  updateHash(currentSurah.number, currentPageIdx);

  /* Build HTML */
  let html = '';

  /* Page ornament */
  html += `
    <div class="page-ornament" aria-hidden="true">
      <div class="page-ornament-line">
        <div class="ornament-dash"></div>
        <span class="ornament-diamond">◆</span>
        <span class="page-label-text">الصفحة ${pg.page}</span>
        <span class="ornament-diamond">◆</span>
        <div class="ornament-dash"></div>
      </div>
    </div>
  `;

  /* Surah header on first page */
  if (pg.firstAyahNum === 1) {
    html += `
      <div class="surah-header-reader" aria-label="سورة ${currentSurah.name}">
        <h2>سُورَةُ ${currentSurah.name}</h2>
        <p>${currentSurah.englishName} · ${currentSurah.numberOfAyahs} آية · ${currentSurah.revelationType === 'Meccan' ? 'مكية' : 'مدنية'}</p>
      </div>
    `;
  }

  /* Basmalah: shown on first page of every surah EXCEPT Al-Fatiha (1) [already included] and At-Tawbah (9) */
  if (pg.firstAyahNum === 1 && currentSurah.number !== 9) {
    html += `<div class="basmalah" aria-label="بسم الله الرحمن الرحيم">${BASMALAH_TEXT}</div>`;
  }

  /* Ayah text with ornament numbers */
  html += '<div>';
  for (const a of pg.ayahs) {
    html += a.text;
    html += '\u202F';
    html += `<span class="ayah-num" aria-label="الآية ${a.numberInSurah}"><span>${toArabicNum(a.numberInSurah)}</span></span>`;
    html += '\u202F';
  }
  html += '</div>';

  document.getElementById('quran-text').innerHTML = html;
  window.scrollTo({ top: 0, behavior: 'instant' });
}

/* ════════════════════════════════════════════════
   ARABIC NUMERALS HELPER
════════════════════════════════════════════════ */
function toArabicNum(n) {
  return String(n).replace(/\d/g, d => '٠١٢٣٤٥٦٧٨٩'[d]);
}

/* ════════════════════════════════════════════════
   PAGE NAVIGATION
════════════════════════════════════════════════ */
function nextPage() {
  if (currentPageIdx < allPages.length - 1) {
    currentPageIdx++;
    renderPage();
  }
}
function prevPage() {
  if (currentPageIdx > 0) {
    currentPageIdx--;
    renderPage();
  }
}

document.getElementById('next-btn').addEventListener('click', nextPage);
document.getElementById('prev-btn').addEventListener('click', prevPage);

/* ════════════════════════════════════════════════
   SHOW / HIDE SCREENS
════════════════════════════════════════════════ */
function showReader() {
  document.body.classList.add('reading');
  document.getElementById('home'      ).style.display      = 'none';
  document.getElementById('reader'    ).style.display      = 'block';
  document.getElementById('pagination').style.display      = 'flex';
}

function showHome() {
  document.body.classList.remove('reading');
  document.getElementById('reader'    ).style.display      = 'none';
  document.getElementById('pagination').style.display      = 'none';
  document.getElementById('home'      ).style.display      = 'block';
  currentSurah   = null;
  allPages       = [];
  currentPageIdx = 0;
  clearHash();
}

document.getElementById('btn-close').addEventListener('click', showHome);

/* ════════════════════════════════════════════════
   LOADER
════════════════════════════════════════════════ */
function showLoader(on) {
  document.getElementById('loader').classList.toggle('active', on);
}

/* ════════════════════════════════════════════════
   TOAST NOTIFICATION
════════════════════════════════════════════════ */
function toast(msg, duration) {
  duration = duration || 4000;
  const el = document.createElement('div');
  el.className = 'toast';
  el.setAttribute('role', 'alert');
  el.setAttribute('aria-live', 'assertive');
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(() => {
    el.style.opacity = '0';
    el.style.transition = 'opacity .3s';
    setTimeout(() => el.remove(), 350);
  }, duration);
}

/* ════════════════════════════════════════════════
   KEYBOARD SHORTCUTS
════════════════════════════════════════════════ */
document.addEventListener('keydown', function(e) {
  const activeEl = document.activeElement;
  const isInput  = ['INPUT','TEXTAREA','SELECT'].includes(activeEl.tagName);
  if (isInput) return;

  switch (e.key) {
    case 'Escape':
      if (currentSurah) { e.preventDefault(); showHome(); }
      break;
    case 'ArrowLeft':
      if (currentSurah) { e.preventDefault(); nextPage(); }
      break;
    case 'ArrowRight':
      if (currentSurah) { e.preventDefault(); prevPage(); }
      break;
   
    case 'd':
    case 'D':
      applyDark(!darkMode);
      break;
  }
});

/* ════════════════════════════════════════════════
   SWIPE SUPPORT (touch devices)
════════════════════════════════════════════════ */
let _touchStartX = 0;
let _touchStartY = 0;
document.addEventListener('touchstart', function(e) {
  _touchStartX = e.changedTouches[0].screenX;
  _touchStartY = e.changedTouches[0].screenY;
}, { passive: true });
document.addEventListener('touchend', function(e) {
  if (!currentSurah) return;
  const dx = e.changedTouches[0].screenX - _touchStartX;
  const dy = e.changedTouches[0].screenY - _touchStartY;
  /* Ignore vertical swipes */
  if (Math.abs(dy) > Math.abs(dx)) return;
  if (Math.abs(dx) < 55) return;
  if (dx < 0) {
    nextPage();
  } else {
    prevPage();
  }
}, { passive: true });

/* ════════════════════════════════════════════════
   LAZY LOADING (Intersection Observer for images/heavy elements)
   Here used conceptually – we ensure pages are only rendered on demand
════════════════════════════════════════════════ */
/* The app already uses on-demand rendering: each page is generated only
   when navigated to. No all-at-once DOM dumping. */

/* ════════════════════════════════════════════════
   SERVICE WORKER REGISTRATION (PWA offline support)
════════════════════════════════════════════════ */
if ('serviceWorker' in navigator) {
  window.addEventListener('load', function() {
    /* Inline service worker as blob */
    const swCode = `
const CACHE = 'quran-v1';
const FONTS  = [
  'https://fonts.googleapis.com/css2?family=Amiri+Quran&family=Amiri:wght@400;700&family=Scheherazade+New:wght@400;700&family=Cairo:wght@300;400;600;700;800&display=swap'
];
self.addEventListener('install', e => {
  e.waitUntil(caches.open(CACHE).then(c => c.addAll(FONTS).catch(()=>{})));
  self.skipWaiting();
});
self.addEventListener('activate', e => {
  e.waitUntil(caches.keys().then(ks => Promise.all(ks.filter(k=>k!==CACHE).map(k=>caches.delete(k)))));
  self.clients.claim();
});
self.addEventListener('fetch', e => {
  if (e.request.method !== 'GET') return;
  e.respondWith(
    caches.match(e.request).then(cached => cached || fetch(e.request).then(resp => {
      if (resp && resp.status === 200 && resp.type === 'basic') {
        const clone = resp.clone();
        caches.open(CACHE).then(c => c.put(e.request, clone));
      }
      return resp;
    }).catch(() => cached))
  );
});
    `;
    try {
      const blob = new Blob([swCode], { type: 'application/javascript' });
      const swUrl = URL.createObjectURL(blob);
      navigator.serviceWorker.register(swUrl).catch(() => {});
    } catch(err) { /* SW not supported in this context */ }
  });
}

/* ════════════════════════════════════════════════
   BOOT
════════════════════════════════════════════════ */
loadSurahList();
</script>
</body>
</html>
